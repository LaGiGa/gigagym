# Frontend: URL do endpoint serverless
# Exemplo para Vercel local/producao:
# VITE_GROQ_API_ENDPOINT=/api/groq-plan
# Exemplo se endpoint estiver em outro dominio:
# VITE_GROQ_API_ENDPOINT=https://seu-dominio.com/api/groq-plan
VITE_GROQ_API_ENDPOINT=/api/groq-plan

# Backend (serverless): configure no provedor de deploy, NAO no frontend
# GROQ_API_KEY=...
